<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:obuvv"
        mc:Ignorable="d" 
        d:DesignWidth="1400" d:DesignHeight="800"
        x:Class="obuvv.OrdersWindow"
        Title="ООО ОБУВЬ - Заказы"
        Icon="avares://obuvv/image/Icon.ico"
        WindowStartupLocation="CenterScreen"
        MinWidth="1200"
        RequestedThemeVariant="Light"
        MinHeight="700"
        Background="White"
        FontFamily="Times New Roman"
        x:DataType="local:OrdersWindow">

    <DockPanel Background="White">
        <Border DockPanel.Dock="Top" 
                Background="White" 
                BorderBrush="#7FFF00"
                BorderThickness="0,0,0,4"
                Height="90"
                Padding="25,5">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Image Grid.Column="0"
                       Source="avares://obuvv/image/Icon.ico"
                       Width="65" Height="65"
                       VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                    <TextBlock Text="ООО ОБУВЬ" 
                               FontSize="14" 
                               HorizontalAlignment="Center"
                               Foreground="Gray" 
                               LetterSpacing="2"/>
                    <TextBlock Text="УПРАВЛЕНИЕ ЗАКАЗАМИ" 
                               FontSize="26" 
                               FontWeight="Black" 
                               Foreground="Black"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <Button x:Name="BackButton"
                            Content="Назад к товарам" 
                            Background="White"
                            BorderBrush="#7FFF00"
                            BorderThickness="2"
                            Foreground="Black"
                            Width="160" 
                            Height="40"
                            FontWeight="Bold"
                            CornerRadius="8"
                            FontSize="12"/>
                    
                    <Button x:Name="AddOrderButton"
                            Content="Новый заказ" 
                            Background="#00FA9A"
                            Foreground="Black"
                            Width="140" 
                            Height="40"
                            FontWeight="Bold"
                            CornerRadius="8"
                            FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="FiltersPanel"
                DockPanel.Dock="Top"
                Background="#FAFAFA"
                Margin="20,15,20,0"
                CornerRadius="12"
                BorderBrush="#EEEEEE"
                BorderThickness="1"
                Height="180"
                Padding="20"
                IsVisible="{Binding IsAdminVisible}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="20">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                    <TextBox x:Name="SearchTextBox"
                             Watermark="Поиск по номеру, клиенту или коду получения..."
                             Height="45"
                             CornerRadius="8"
                             Background="White"
                             BorderBrush="#7FFF00"
                             BorderThickness="1"
                             VerticalContentAlignment="Center"
                             FontSize="13"/>
                    
                    <Button Grid.Column="1"
                            x:Name="ClearSearchButton"
                            Content="Очистить поиск"
                            Background="White"
                            BorderBrush="#7FFF00"
                            BorderThickness="1"
                            Foreground="Black"
                            Width="140"
                            Height="45"
                            FontWeight="Bold"
                            CornerRadius="8"/>
                    
                    <Button Grid.Column="2"
                            x:Name="ResetFiltersButton"
                            Content="Сбросить фильтры"
                            Background="White"
                            BorderBrush="#7FFF00"
                            BorderThickness="1"
                            Foreground="Black"
                            Width="140"
                            Height="45"
                            FontWeight="Bold"
                            CornerRadius="8"/>
                    
                    <StackPanel Grid.Column="3"
                               Orientation="Horizontal"
                               VerticalAlignment="Center"
                               Spacing="8">
                        <TextBlock Text="Сортировка:"
                                  FontSize="11"
                                  FontWeight="Bold"
                                  VerticalAlignment="Center"/>
                        <ComboBox x:Name="SortComboBox"
                                 Width="200"
                                 Height="35"
                                 FontSize="13"
                                 Background="White"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 CornerRadius="4"
                                 VerticalAlignment="Center"
                                 SelectedIndex="0">
                            <ComboBoxItem>По дате (новые)</ComboBoxItem>
                            <ComboBoxItem>По дате (старые)</ComboBoxItem>
                            <ComboBoxItem>По сумме (возрастание)</ComboBoxItem>
                            <ComboBoxItem>По сумме (убывание)</ComboBoxItem>
                            <ComboBoxItem>По номеру (возрастание)</ComboBoxItem>
                            <ComboBoxItem>По номеру (убывание)</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                </Grid>
                
                <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="20">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Статус заказа:" 
                                   FontSize="11" 
                                   FontWeight="Bold" 
                                   Margin="0,0,0,2"/>
                        <ComboBox x:Name="StatusComboBox"
                                 Width="180"
                                 Height="35"
                                 FontSize="13"
                                 Background="White"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 CornerRadius="4"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Дата с:"
                                  FontSize="11"
                                  FontWeight="Bold"
                                  Margin="0,0,0,2"/>
                        <DatePicker x:Name="DateFromPicker"
                                   Width="150"
                                   Height="35"
                                   FontSize="13"
                                   Background="White"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   CornerRadius="4"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="Дата по:"
                                  FontSize="11"
                                  FontWeight="Bold"
                                  Margin="0,0,0,2"/>
                        <DatePicker x:Name="DateToPicker"
                                   Width="150"
                                   Height="35"
                                   FontSize="13"
                                   Background="White"
                                   BorderBrush="#CCCCCC"
                                   BorderThickness="1"
                                   CornerRadius="4"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="3" Spacing="4">
                        <TextBlock Text="Точка выдачи:"
                                  FontSize="11"
                                  FontWeight="Bold"
                                  Margin="0,0,0,2"/>
                        <ComboBox x:Name="PickupPointComboBox"
                                 Width="200"
                                 Height="35"
                                 FontSize="13"
                                 Background="White"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 CornerRadius="4"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    Margin="0,0,10,0"
                    CornerRadius="12">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0"
                            Background="#7FFF00"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,15">
                        <TextBlock Text="ДЕТАЛИ ЗАКАЗА"
                                  FontWeight="Bold"
                                  FontSize="18"
                                  Foreground="Black"
                                  HorizontalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Row="1"
                                Spacing="12"
                                Margin="0,0,0,15">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                      Text="Номер заказа:"
                                      FontWeight="Bold"
                                      Foreground="#666666"
                                      Width="130"/>
                            <TextBlock Grid.Column="1"
                                      x:Name="DetailOrderNumber"
                                      Text="-" 
                                      FontWeight="Bold"
                                      Foreground="#333333"
                                      FontSize="14"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                      Text="Код получения:"
                                      FontWeight="Bold"
                                      Foreground="#666666"
                                      Width="130"/>
                            <TextBlock Grid.Column="1"
                                      x:Name="DetailReceiptCode"
                                      Text="-" 
                                      FontWeight="Bold"
                                      Foreground="#333333"
                                      FontSize="14"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                      Text="Статус:"
                                      FontWeight="Bold"
                                      Foreground="#666666"
                                      Width="130"/>
                            <Border Grid.Column="1"
                                    x:Name="DetailStatusBorder"
                                    Padding="8,4"
                                    CornerRadius="4"
                                    Background="#7FFF00"
                                    HorizontalAlignment="Left">
                                <TextBlock x:Name="DetailStatus"
                                          Text="-"
                                          FontWeight="Bold"
                                          Foreground="Black"/>
                            </Border>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                      Text="Дата заказа:"
                                      FontWeight="Bold"
                                      Foreground="#666666"
                                      Width="130"/>
                            <TextBlock Grid.Column="1"
                                      x:Name="DetailOrderDate"
                                      Text="-"
                                      Foreground="#333333"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                      Text="Дата доставки:"
                                      FontWeight="Bold"
                                      Foreground="#666666"
                                      Width="130"/>
                            <TextBlock Grid.Column="1"
                                      x:Name="DetailDeliveryDate"
                                      Text="-"
                                      Foreground="#333333"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                      Text="Клиент:"
                                      FontWeight="Bold"
                                      Foreground="#666666"
                                      Width="130"/>
                            <TextBlock Grid.Column="1"
                                      x:Name="DetailClient"
                                      Text="-"
                                      Foreground="#333333"/>
                        </Grid>
                        
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0"
                                      Text="Точка выдачи:"
                                      FontWeight="Bold"
                                      Foreground="#666666"
                                      Width="130"/>
                            <TextBlock Grid.Column="1"
                                      x:Name="DetailPickupPoint"
                                      Text="-"
                                      Foreground="#333333"/>
                        </Grid>
                    </StackPanel>
                    
                    <Border Grid.Row="2"
                            Background="#F0F0F0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            Height="35"
                            Padding="10,0"
                            Margin="0,0,0,10"
                            CornerRadius="4">
                        <Grid ColumnDefinitions="70,*,45,80">
                            <TextBlock Grid.Column="0"
                                      Text="Артикул"
                                      FontWeight="Bold"
                                      FontSize="12"
                                      Foreground="#333333"/>
                            
                            <TextBlock Grid.Column="1"
                                      Text="Наименование"
                                      FontWeight="Bold"
                                      FontSize="12"
                                      Foreground="#333333"/>
                            
                            <TextBlock Grid.Column="2"
                                      Text="Кол-во"
                                      FontWeight="Bold"
                                      FontSize="12"
                                      Foreground="#333333"
                                      HorizontalAlignment="Center"/>
                            
                            <TextBlock Grid.Column="3"
                                      Text="Сумма"
                                      FontWeight="Bold"
                                      FontSize="12"
                                      Foreground="#333333"
                                      HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Row="4"
                            Background="White"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,1,1"
                            Margin="0,0,0,10"
                            CornerRadius="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding OrderDetails}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#F0F0F0"
                                                BorderThickness="0,0,0,1"
                                                Padding="10,6">
                                            <Grid ColumnDefinitions="70,*,45,80">
                                                <TextBlock Grid.Column="0"
                                                          Text="{Binding Article}"
                                                          FontSize="11"
                                                          Foreground="#666666"
                                                          VerticalAlignment="Center"/>
                                                
                                                <TextBlock Grid.Column="1"
                                                          Text="{Binding ProductName}"
                                                          FontWeight="SemiBold"
                                                          Foreground="#333333"
                                                          TextWrapping="Wrap"
                                                          VerticalAlignment="Center"
                                                          FontSize="11"/>
                                                
                                                <TextBlock Grid.Column="2"
                                                          Text="{Binding Quantity}"
                                                          Foreground="#333333"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"
                                                          FontSize="11"/>
                                                
                                                <TextBlock Grid.Column="3"
                                                          Text="{Binding TotalPriceFormatted}"
                                                          FontWeight="Bold"
                                                          Foreground="#333333"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Right"
                                                          FontSize="11"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    
                    <Border Grid.Row="5"
                            Background="#7FFF00"
                            CornerRadius="8"
                            Padding="15">
                        <Grid ColumnDefinitions="*,100">
                            <TextBlock Grid.Column="0"
                                      Text="ИТОГО:"
                                      FontWeight="Bold"
                                      FontSize="16"
                                      Foreground="Black"
                                      VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Column="1"
                                      x:Name="DetailTotalAmount"
                                      Text="0.00 ₽"
                                      FontWeight="Bold"
                                      FontSize="18"
                                      Foreground="Black"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            
            <GridSplitter Grid.Column="0"
                         Width="3"
                         Background="#E0E0E0"
                         HorizontalAlignment="Right"
                         ShowsPreview="True"/>
            
            <ScrollViewer Grid.Column="1"
                         Background="White"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Margin="3,0,0,0">
                <ItemsControl x:Name="OrdersItemsControl" 
                             ItemsSource="{Binding Orders}"
                             Background="White">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" 
                                    BorderThickness="1" 
                                    Background="{Binding BackgroundColor}"
                                    CornerRadius="12"
                                    Padding="20"
                                    Margin="0,0,0,15"
                                    PointerPressed="OrderItem_PointerPressed"
                                    Cursor="Hand"
                                    BoxShadow="0 2 6 0 #10000000">
                                
                                <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="15">
                                    
                                    <StackPanel Grid.Column="0" Spacing="8">
                                        <Border Background="#7FFF00"
                                                CornerRadius="6"
                                                Padding="6,4"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding OrderNumber, StringFormat='Заказ №{0}'}"
                                                      FontWeight="Bold"
                                                      FontSize="14"
                                                      Foreground="Black"/>
                                        </Border>
                                        
                                        <StackPanel Spacing="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Статус:"
                                                          FontWeight="Bold"
                                                          Foreground="#666666"
                                                          Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1"
                                                          Text="{Binding StatusDisplay}"
                                                          Foreground="#333333"
                                                          FontWeight="SemiBold"/>
                                            </Grid>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Точка выдачи:"
                                                          FontWeight="Bold"
                                                          Foreground="#666666"
                                                          Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1"
                                                          Text="{Binding PickupPoint}"
                                                          Foreground="#333333"
                                                          TextWrapping="Wrap"
                                                          FontSize="12"/>
                                            </Grid>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Дата заказа:"
                                                          FontWeight="Bold"
                                                          Foreground="#666666"
                                                          Margin="0,0,6,0"/>
                                                <TextBlock Grid.Column="1"
                                                          Text="{Binding OrderDateFormatted}"
                                                          Foreground="#333333"
                                                          FontSize="12"/>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                               Spacing="4"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock Text="Дата доставки"
                                                  FontSize="12"
                                                  FontWeight="Bold"
                                                  Foreground="#666666"/>
                                        <TextBlock Text="{Binding DeliveryDateFormatted}"
                                                  FontWeight="Bold"
                                                  FontSize="14"
                                                  Foreground="#333333"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                               Spacing="8"
                                               IsVisible="{Binding IsAdmin}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">

                                        <Button Content="УДАЛИТЬ"
                                                Background="#7FFF00"
                                                Foreground="Black"
                                                Click="DeleteOrderButton_Click"
                                                CommandParameter="{Binding}"
                                                Width="110"
                                                Height="32"
                                                FontWeight="Bold"
                                                CornerRadius="6"
                                                FontSize="11"
                                                BorderThickness="0"/>

                                        <Button Content="ИЗМЕНИТЬ"
                                                Background="#00FA9A"
                                                Foreground="Black"
                                                Click="EditOrderButton_Click"
                                                CommandParameter="{Binding}"
                                                Width="110"
                                                Height="32"
                                                FontWeight="Bold"
                                                CornerRadius="6"
                                                FontSize="11"
                                                BorderThickness="0"/>
                                    </StackPanel>
                                    
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>